# Required for production
RELAY=wss://bsky.network
DID_PLC_URL=https://plc.directory
PORT=3000
DATABASE=data/hatk.db
# On Railway: OAUTH_ISSUER=https://${{RAILWAY_PUBLIC_DOMAIN}}
OAUTH_ISSUER=https://your-app.example.com

# Admin access (comma-separated DIDs)
# ADMINS=did:plc:xxx

# Optional
# BACKFILL_REPOS=did:plc:xxx,did:plc:yyy
# BACKFILL_FULL_NETWORK=false
# BACKFILL_PARALLELISM=5
# FTS_REBUILD_INTERVAL=500

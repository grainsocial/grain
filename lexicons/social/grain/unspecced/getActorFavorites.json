{
  "lexicon": 1,
  "id": "social.grain.unspecced.getActorFavorites",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get galleries favorited by the authenticated actor. Only the actor themselves can view their favorites.",
      "parameters": {
        "type": "params",
        "required": ["actor"],
        "properties": {
          "actor": { "type": "string", "format": "did" },
          "limit": { "type": "integer", "minimum": 1, "maximum": 100, "default": 30 },
          "cursor": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["items"],
          "properties": {
            "items": {
              "type": "array",
              "items": { "type": "ref", "ref": "social.grain.gallery.defs#galleryView" }
            },
            "cursor": { "type": "string" }
          }
        }
      }
    }
  }
}

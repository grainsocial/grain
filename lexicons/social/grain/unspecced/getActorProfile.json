{
  "lexicon": 1,
  "id": "social.grain.unspecced.getActorProfile",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get an actor's profile with gallery stats and follow relationships.",
      "parameters": {
        "type": "params",
        "required": ["actor"],
        "properties": {
          "actor": { "type": "string", "format": "did" },
          "viewer": { "type": "string", "format": "did" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "social.grain.actor.defs#profileViewDetailed"
        }
      }
    }
  }
}
